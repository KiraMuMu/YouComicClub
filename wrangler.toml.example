#:schema ./node_modules/wrangler/config-schema.json

name = "youclub-auth"
main = "worker/auth.js"
compatibility_date = "2024-12-05"
compatibility_flags = ["nodejs_compat"]

# KV 绑定
[[kv_namespaces]]
binding = "AUTH_KV"
id = "your-kv-namespace-id"

# 环境变量
[vars]
FRONTEND_URL = "https://your-domain.com"
SMTP_FROM_EMAIL = "noreply@your-domain.workers.dev"
BANGUMI_REDIRECT_URI = "https://your-worker.workers.dev/api/auth/bangumi/callback"
TURNSTILE_SECRET_KEY = "your-turnstile-secret-key"

# JWT 密钥（生产环境请使用 wrangler secret put JWT_SECRET 设置）
JWT_SECRET = "change-this-to-a-strong-random-secret-key-min-32-chars"

# Bangumi OAuth（如果需要，填写你自己的 Client ID 和 Secret）
# BANGUMI_CLIENT_ID = "your-bangumi-client-id"
# BANGUMI_CLIENT_SECRET = "your-bangumi-client-secret"
